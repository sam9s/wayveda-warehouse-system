# ===========================================
# WayVeda Warehouse System — Environment Config
# ===========================================
# Copy this to .env and fill in actual values
# NEVER commit .env to version control
# ===========================================

# App
NODE_ENV=production
PORT=4002

# Supabase (self-hosted)
# Get these from /root/supabase/supabase/docker/.env after setup
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
# Host-side Node access on the self-hosted stack uses Supavisor session mode
DATABASE_URL=postgresql://postgres.your-tenant-id:your-db-password@localhost:5432/postgres

# Shiprocket API
# Create API user at: Shiprocket Panel > Settings > API > Configure
# Use a dedicated API email, not the admin account
SHIPROCKET_EMAIL=your-shiprocket-api-email
SHIPROCKET_PASSWORD=your-shiprocket-api-password
SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in/v1/external

# Auth
JWT_SECRET=generate-with-openssl-rand-base64-32

# CORS
CORS_ORIGIN=https://wh.wayveda.cloud
PUBLIC_APP_URL=https://wh.wayveda.cloud
