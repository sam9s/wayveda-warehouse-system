{
  "name": "wayveda-warehouse-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Phase B database foundation and import tooling for the WayVeda Warehouse System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:migrate": "node src/db/migrate.js",
    "db:seed:products": "node src/db/seed-products.js",
    "db:import:history": "node src/db/import-historical-data.js",
    "db:verify:ledger": "node src/db/verify-ledger.js",
    "db:phase-b": "npm run db:migrate && npm run db:seed:products && npm run db:import:history && npm run db:verify:ledger",
    "verify:auth-flows": "node src/scripts/verify-auth-flows.js",
    "user:create": "node src/scripts/create-user.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "pg": "^8.16.3"
  }
}
